# Build output (regenerated by deploy.bat / vite build)
deploy/

# Raw source material — too large for git.
# Anchored to the repo root: a bare `audio/` also matches app/src/audio (source
# code) and app/public/audio (product stems), silently dropping new files there.
/transfer/
/audio/
/temp/
/old/

# gstack tooling state
.gstack/

# personal Claude Code settings (per-user, not for the repo)
.claude/settings.local.json

# Capacitor mobile build output (regenerated by npm run build:mobile)
app/dist-mobile/

# Markdown docs — kept local, omitted from the public repo
*.md
